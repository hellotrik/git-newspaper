{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "git-newspaper: pack",
      "identifier": "git-newspaper-pack",
      "type": "shell",
      "command": "npm pack",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "icon": {
        "id": "gift",
        "tooltip": "生成 npm 安装包 (.tgz)"
      }
    },
    {
      "label": "git-newspaper: install",
      "identifier": "git-newspaper-install",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "icon": {
        "id": "tools",
        "tooltip": "安装项目依赖 (node_modules)"
      }
    }
  ]
}
