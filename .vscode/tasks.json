{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "git-newspaper: pack",
      "identifier": "git-newspaper-pack",
      "type": "shell",
      "command": "npm pack",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "icon": {
        "id": "gift",
        "tooltip": "生成 npm 安装包 (.tgz)"
      }
    },
    {
      "label": "git-newspaper: install",
      "identifier": "git-newspaper-install",
      "type": "shell",
      "command": "sudo npm install -g \"./$(node -e \"const p=require('./package.json'); process.stdout.write(p.name+'-'+p.version+'.tgz')\")\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "icon": {
        "id": "rocket",
        "tooltip": "全局安装本地包：npm install -g ./git-newspaper-<版本>.tgz（版本从 package.json 读取，需先执行 pack）"
      }
    }
  ]
}
